<% let currentQty = 0; if (Array.isArray(cartItems)) { const found =
cartItems.find(it => String(it.foodId) === String(food._id)); if (found)
currentQty = found.qty; } %>

<div
  class="card shadow-sm border-0"
  style="border-radius: 15px; position: relative"
>
  <!-- Loading Overlay -->
  <div
    class="card-overlay"
    style="
      display: none;
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(255, 255, 255, 0.7);
      border-radius: 15px;
      z-index: 10;
    "
  ></div>
  <a href="/foods/<%= food._id %>">
    <img
      src="<%= food.imageUrl %>"
      alt="<%= food.name %>"
      class="card-img-top"
      style="height: 180px; object-fit: cover; border-radius: 15px 15px 0 0"
    />
  </a>

  <div class="card-body">
    <h5 class="card-title fw-bold"><%= food.name %></h5>
    <p class="card-text text-muted" style="min-height: 40px">
      <%= food.description %>
    </p>

    <div class="d-flex justify-content-between align-items-center">
      <span class="text-danger fw-bold">$<%= food.price %></span>

      <!-- CART CONTROL -->
      <div
        class="cart-control"
        data-id="<%= food._id %>"
        style="position: relative; z-index: 5"
      >
        <!-- ADD BUTTON (shown only when qty = 0) -->
        <% if (currentQty < 1) {%>
        <form
          action="/api/food/cart/add/<%= food._id %>"
          method="POST"
          style="display: inline"
        >
          <button class="btn btn-sm btn-warning text-white">Add</button>
        </form>

        <% }else { %>

        <!-- QUANTITY WRAPPER (shown only when qty > 0) -->
        <div
          class="quantity-wrapper d-flex align-items-center justify-content-between px-2 py-1"
          style="
            background:white;
            border-radius: 25px;
            width:90px;
            height:34px;
            box-shadow:0 0 4px rgba(0,0,0,0.15);
            display: <%= currentQty > 0 ? 'flex' : 'none' %>;
          "
          data-qty="<%= currentQty %>"
        >
          <button
            class="btn btn-sm p-0 qty-minus"
            style="
              background: #ffdddd;
              border-radius: 50%;
              width: 25px;
              height: 25px;
              color: #d9534f;
              font-size: 18px;
            "
          >
            –
          </button>

          <span class="qty-value fw-bold" style="font-size: 16px">
            <%= currentQty || 1 %>
          </span>

          <button
            class="btn btn-sm p-0 qty-plus"
            style="
              background: #ddffdd;
              border-radius: 50%;
              width: 25px;
              height: 25px;
              color: #5cb85c;
              font-size: 18px;
            "
          >
            +
          </button>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".card").forEach((card) => {
      const control = card.querySelector(".cart-control");
      const overlay = card.querySelector(".card-overlay");

      if (!control || !overlay) return;

      const foodId = control.dataset.id;
      const qtyWrapper = control.querySelector(".quantity-wrapper");

      if (!qtyWrapper) return;

      const qtyValue = qtyWrapper.querySelector(".qty-value");
      const qtyMinus = qtyWrapper.querySelector(".qty-minus");
      const qtyPlus = qtyWrapper.querySelector(".qty-plus");

      const showOverlay = () => {
        overlay.style.display = "block";
      };

      const hideOverlay = () => {
        overlay.style.display = "none";
      };

      qtyMinus.addEventListener("click", async () => {
        showOverlay();
        const currentQty = parseInt(qtyValue.textContent);
        const newQty = currentQty - 1;

        const response = await fetch(`/api/food/cart/update/${foodId}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action: "dec" }),
        });

        if (response.ok) {
          if (newQty <= 0) {
            control.innerHTML = `<form action='/api/food/cart/add/${foodId}' method='POST' style='display: inline'>
              <button class='btn btn-sm btn-warning text-white'>Add</button>
            </form>`;
          } else {
            qtyValue.textContent = newQty;
          }
        }

        hideOverlay();
      });

      qtyPlus.addEventListener("click", async () => {
        showOverlay();
        const currentQty = parseInt(qtyValue.textContent);
        const newQty = currentQty + 1;

        const response = await fetch(`/api/food/cart/update/${foodId}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action: "inc" }),
        });

        if (response.ok) {
          qtyValue.textContent = newQty;
        }

        hideOverlay();
      });
    });
  });
</script>
